    "ws-chap-body": {
      "א": {
        "prefix": [
          {
            "stmpl": "מ:רווח בתרי עשר בפסוק הראשון|עֹבדיה"
          }
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|א"
        },
        "verse-body": [
          "חֲז֖וֹן עֹֽבַדְיָ֑ה כֹּֽה־אָמַר֩ אֲדֹנָ֨י יֱהֹוִ֜ה לֶאֱד֗וֹם שְׁמוּעָ֨ה שָׁמַ֜עְנוּ מֵאֵ֤ת יְהֹוָה֙ וְצִיר֙ בַּגּוֹיִ֣ם שֻׁלָּ֔ח ק֛וּמוּ וְנָק֥וּמָה ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "עָלֶ֖יהָ"
              ],
              [
                "2=ל=עָלֶיהָ (טעם המרכא חסר!)",
                {
                  "stmpl": "ש"
                },
                "הערת המקליד בגירסה 4.16."
              ]
            ]
          },
          " לַמִּלְחָמָֽה׃"
        ]
      },
      "ב": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ב"
        },
        "verse-body": [
          "הִנֵּ֥ה קָטֹ֛ן נְתַתִּ֖יךָ בַּגּוֹיִ֑ם בָּז֥וּי אַתָּ֖ה מְאֹֽד׃"
        ]
      },
      "ג": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ג"
        },
        "verse-body": [
          "זְד֤וֹן לִבְּךָ֙ הִשִּׁיאֶ֔ךָ שֹׁכְנִ֥י ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "בְחַגְוֵי־סֶ֖לַע"
              ],
              [
                "2==ל?,ק,ש1? ובדפוסים (וכן הכריעו ברויאר ומג\"ה)",
                {
                  "stmpl": "ש"
                },
                "ל?=בְחַגְוֵי־סֶּ֖לַע (סמ\"ך דגושה?) לפי המקליד ולפי ברויאר בספק, בְחַגְוֵי־סֶ֖לַע (בלי דגש) לפי דותן. קשה להבחין בכתי\"ל אם מדובר בדגש או בכתם דיו בסמ\"ך."
              ]
            ]
          },
          " מְר֣וֹם שִׁבְתּ֑וֹ אֹמֵ֣ר בְּלִבּ֔וֹ מִ֥י יוֹרִדֵ֖נִי אָֽרֶץ׃"
        ]
      },
      "ד": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ד"
        },
        "verse-body": [
          "אִם־תַּגְבִּ֣יהַּ כַּנֶּ֔שֶׁר וְאִם־בֵּ֥ין כּֽוֹכָבִ֖ים שִׂ֣ים קִנֶּ֑ךָ מִשָּׁ֥ם אוֹרִֽידְךָ֖ נְאֻם־יְהֹוָֽה׃"
        ]
      },
      "ה": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ה"
        },
        "verse-body": [
          "אִם־גַּנָּבִ֤ים בָּאֽוּ־לְךָ֙ אִם־שׁ֣וֹדְדֵי לַ֔יְלָה אֵ֣יךְ נִדְמֵ֔יתָה הֲל֥וֹא יִגְנְב֖וּ דַּיָּ֑ם אִם־בֹּֽצְרִים֙ בָּ֣אוּ לָ֔ךְ הֲל֖וֹא יַשְׁאִ֥ירוּ עֹלֵלֽוֹת׃"
        ]
      },
      "ו": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ו"
        },
        "verse-body": [
          "אֵ֚יךְ נֶחְפְּשׂ֣וּ עֵשָׂ֔ו נִבְע֖וּ מַצְפֻּנָֽיו׃"
        ]
      },
      "ז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ז"
        },
        "verse-body": [
          "עַֽד־הַגְּב֣וּל שִׁלְּח֗וּךָ כֹּ֚ל אַנְשֵׁ֣י בְרִיתֶ֔ךָ הִשִּׁיא֛וּךָ יָכְל֥וּ לְךָ֖ אַנְשֵׁ֣י שְׁלֹמֶ֑ךָ לַחְמְךָ֗ יָשִׂ֤ימוּ מָזוֹר֙ תַּחְתֶּ֔יךָ אֵ֥ין תְּבוּנָ֖ה בּֽוֹ׃"
        ]
      },
      "ח": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ח"
        },
        "verse-body": [
          "הֲל֛וֹא בַּיּ֥וֹם הַה֖וּא ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "נְאֻם־יְהֹוָ֑ה"
              ],
              [
                "2==ל?,ק ובדפוסים",
                {
                  "stmpl": "ש"
                },
                "ל?=<נְאֻם יְהֹוָ֑ה> (חסר מקף?) לפי המקליד בגירסה 4.14, אבל בגירסה 4.16 הוסיף את המקף וכן בדותן. ניתן בקושי להבחין במקף בצילום כתי\"ל בהגדלה."
              ]
            ]
          },
          " וְהַאֲבַדְתִּ֤י חֲכָמִים֙ מֵֽאֱד֔וֹם וּתְבוּנָ֖ה מֵהַ֥ר עֵשָֽׂו׃"
        ]
      },
      "ט": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|ט"
        },
        "verse-body": [
          "וְחַתּ֥וּ גִבּוֹרֶ֖יךָ תֵּימָ֑ן לְמַ֧עַן יִכָּֽרֶת־אִ֛ישׁ מֵהַ֥ר עֵשָׂ֖ו מִקָּֽטֶל׃"
        ]
      },
      "י": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|י"
        },
        "verse-body": [
          "מֵחֲמַ֛ס אָחִ֥יךָ יַעֲקֹ֖ב תְּכַסְּךָ֣ בוּשָׁ֑ה וְנִכְרַ֖תָּ לְעוֹלָֽם׃"
        ]
      },
      "יא": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יא"
        },
        "verse-body": [
          "בְּיוֹם֙ ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                {
                  "stmpl": "מ:קמץ|ד=עֲמׇֽדְךָ֣|ס=עֲמָֽדְךָ֣"
                }
              ],
              [
                "2=לגבי הקמץ הקטן ראו ויינברג 3.2.1.3."
              ]
            ]
          },
          " מִנֶּ֔גֶד בְּי֛וֹם שְׁב֥וֹת זָרִ֖ים חֵיל֑וֹ וְנׇכְרִ֞ים בָּ֣אוּ ",
          {
            "stmpl": "קו\"כ-אם|שְׁעָרָ֗ו|2=ל-קרי=שְׁעָרָ֗יו"
          },
          " וְעַל־יְרוּשָׁל",
          {
            "stmpl": "מ:ירושלם|ַ|֙"
          },
          "ם֙ יַדּ֣וּ גוֹרָ֔ל גַּם־אַתָּ֖ה כְּאַחַ֥ד מֵהֶֽם׃"
        ]
      },
      "יב": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יב"
        },
        "verse-body": [
          "וְאַל־תֵּ֤רֶא בְיוֹם־אָחִ֙יךָ֙ בְּי֣וֹם נׇכְר֔וֹ וְאַל־תִּשְׂמַ֥ח ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "לִבְנֵֽי־יְהוּדָ֖ה"
              ],
              [
                "2==ק ובדפוסים",
                {
                  "stmpl": "ש"
                },
                "ל!=<לִבְנֵֽי יְהוּדָ֖ה> (חסר מקף) לפי ברויאר (וכך נראה בצילום כתי\"ל), אבל דותן והמקליד קראו במקף."
              ]
            ]
          },
          " בְּי֣וֹם אׇבְדָ֑ם וְאַל־תַּגְדֵּ֥ל פִּ֖יךָ בְּי֥וֹם צָרָֽה׃"
        ]
      },
      "יג": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יג"
        },
        "verse-body": [
          "אַל־תָּב֤וֹא בְשַֽׁעַר־עַמִּי֙ בְּי֣וֹם אֵידָ֔ם אַל־תֵּ֧רֶא גַם־אַתָּ֛ה בְּרָעָת֖וֹ בְּי֣וֹם אֵיד֑וֹ וְאַל־תִּשְׁלַ֥חְנָה בְחֵיל֖וֹ בְּי֥וֹם אֵידֽוֹ׃"
        ]
      },
      "יד": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יד"
        },
        "verse-body": [
          "וְאַֽל־תַּעֲמֹד֙ עַל־הַפֶּ֔רֶק לְהַכְרִ֖ית אֶת־פְּלִיטָ֑יו וְאַל־תַּסְגֵּ֥ר שְׂרִידָ֖יו בְּי֥וֹם צָרָֽה׃"
        ]
      },
      "טו": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|טו"
        },
        "verse-body": [
          "כִּֽי־קָר֥וֹב יוֹם־יְהֹוָ֖ה עַל־כׇּל־הַגּוֹיִ֑ם כַּאֲשֶׁ֤ר עָשִׂ֙יתָ֙ יֵעָ֣שֶׂה לָּ֔ךְ גְּמֻלְךָ֖ יָשׁ֥וּב בְּרֹאשֶֽׁךָ׃"
        ]
      },
      "טז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|טז"
        },
        "verse-body": [
          "כִּ֗י כַּֽאֲשֶׁ֤ר שְׁתִיתֶם֙ עַל־הַ֣ר קׇדְשִׁ֔י יִשְׁתּ֥וּ כׇֽל־הַגּוֹיִ֖ם תָּמִ֑יד וְשָׁת֣וּ וְלָע֔וּ וְהָי֖וּ כְּל֥וֹא ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "הָיֽוּ"
              ],
              [
                "2==ק ובדפוסים",
                {
                  "stmpl": "ש"
                },
                "ל!=הָֽיוּ (מקום הסילוק) לפי ברויאר, ונראה שהצדק עמו."
              ]
            ]
          },
          "׃"
        ]
      },
      "יז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יז"
        },
        "verse-body": [
          "וּבְהַ֥ר צִיּ֛וֹן תִּהְיֶ֥ה פְלֵיטָ֖ה וְהָ֣יָה קֹ֑דֶשׁ ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "וְיָֽרְשׁוּ֙"
              ],
              [
                "2==ל,ק",
                {
                  "stmpl": "ש"
                },
                "אך לפי ברויאר ודותן אין געיה.",
                {
                  "stmpl": "ש"
                },
                "קורן, ברויאר, סימנים, מכון ממרא"
              ]
            ]
          },
          " בֵּ֣ית יַֽעֲקֹ֔ב אֵ֖ת ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "מוֹרָֽשֵׁיהֶֽם"
              ],
              [
                "2=ל!=מוֹרָֽשֵׁיהֶם (חסר סילוק)",
                {
                  "stmpl": "ש"
                },
                "הערת המקליד"
              ]
            ]
          },
          "׃"
        ]
      },
      "יח": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יח"
        },
        "verse-body": [
          {
            "stmpl": "נוסח|וְהָיָה֩|2=הערת המקליד בתיבה זו אינה מובנת."
          },
          " בֵית־יַעֲקֹ֨ב אֵ֜שׁ וּבֵ֧ית יוֹסֵ֣ף לֶהָבָ֗ה וּבֵ֤ית עֵשָׂו֙ לְקַ֔שׁ וְדָלְק֥וּ בָהֶ֖ם וַאֲכָל֑וּם ",
          {
            "tmpl": [
              [
                "נוסח"
              ],
              [
                "וְלֹֽא־יִֽהְיֶ֤ה"
              ],
              [
                "2==ל",
                {
                  "stmpl": "ש"
                },
                "ב-BHS ו-BHQ לא גרסו את הגעיה ביו\"ד. אמנם שתי הגעיות קיימות בכתי\"ל, וכן דעתם של דותן וברויאר."
              ]
            ]
          },
          " שָׂרִיד֙ לְבֵ֣ית עֵשָׂ֔ו כִּ֥י יְהֹוָ֖ה דִּבֵּֽר׃"
        ]
      },
      "יט": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|יט"
        },
        "verse-body": [
          "וְיָרְשׁ֨וּ הַנֶּ֜גֶב אֶת־הַ֣ר עֵשָׂ֗ו וְהַשְּׁפֵלָה֙ אֶת־פְּלִשְׁתִּ֔ים וְיָרְשׁוּ֙ אֶת־שְׂדֵ֣ה אֶפְרַ֔יִם וְאֵ֖ת שְׂדֵ֣ה שֹׁמְר֑וֹן וּבִנְיָמִ֖ן אֶת־הַגִּלְעָֽד׃"
        ]
      },
      "כ": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|כ"
        },
        "verse-body": [
          "וְגָלֻ֣ת הַֽחֵל־הַ֠זֶּ֠ה לִבְנֵ֨י יִשְׂרָאֵ֤ל אֲשֶֽׁר־כְּנַעֲנִים֙ עַד־צָ֣רְפַ֔ת וְגָלֻ֥ת יְרוּשָׁל",
          {
            "stmpl": "מ:ירושלם|ַ|֖"
          },
          "ם אֲשֶׁ֣ר בִּסְפָרַ֑ד יִֽרְשׁ֕וּ אֵ֖ת עָרֵ֥י הַנֶּֽגֶב׃"
        ]
      },
      "כא": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|עובדיה|א|כא|סדר=ט"
        },
        "verse-body": [
          "וְעָל֤וּ מֽוֹשִׁעִים֙ בְּהַ֣ר צִיּ֔וֹן לִשְׁפֹּ֖ט אֶת־הַ֣ר עֵשָׂ֑ו וְהָיְתָ֥ה לַֽיהֹוָ֖ה הַמְּלוּכָֽה׃"
        ]
      }
    },
