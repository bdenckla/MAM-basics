        "verse-body": [
          "תְּפִלָּ֖ה לַחֲבַקּ֣וּק הַנָּבִ֑יא עַ֖ל שִׁגְיֹנֽוֹת׃"
        ]
      },
      "ב": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ב"
        },
        "verse-body": [
          "יְהֹוָ֗ה שָׁמַ֣עְתִּי שִׁמְעֲךָ֮ יָרֵ֒אתִי֒ יְהֹוָ֗ה ",
          {
            "stmpl": "מ:קמץ|ד=פׇּֽעׇלְךָ֙|ס=פָּֽעׇלְךָ֙"
          },
          " בְּקֶ֤רֶב שָׁנִים֙ חַיֵּ֔יהוּ בְּקֶ֥רֶב שָׁנִ֖ים תּוֹדִ֑יעַ בְּרֹ֖גֶז רַחֵ֥ם תִּזְכּֽוֹר׃"
        ]
      },
      "ג": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ג"
        },
        "verse-body": [
          "אֱל֙וֹהַּ֙ מִתֵּימָ֣ן יָב֔וֹא וְקָד֥וֹשׁ מֵהַר־פָּארָ֖ן סֶ֑לָה כִּסָּ֤ה שָׁמַ֙יִם֙ הוֹד֔וֹ וּתְהִלָּת֖וֹ מָלְאָ֥ה הָאָֽרֶץ׃"
        ]
      },
      "ד": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ד"
        },
        "verse-body": [
          "וְנֹ֙גַהּ֙ כָּא֣וֹר תִּֽהְיֶ֔ה קַרְנַ֥יִם מִיָּד֖וֹ ל֑וֹ וְשָׁ֖ם חֶבְי֥וֹן עֻזֹּֽה׃"
        ]
      },
      "ה": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ה"
        },
        "verse-body": [
          "לְפָנָ֖יו יֵ֣לֶךְ דָּ֑בֶר וְיֵצֵ֥א רֶ֖שֶׁף לְרַגְלָֽיו׃"
        ]
      },
      "ו": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ו"
