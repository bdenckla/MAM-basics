          " וַיְמֹ֣דֶד אֶ֗רֶץ רָאָה֙ וַיַּתֵּ֣ר גּוֹיִ֔ם ",
          {
            "stmpl": "נוסח|וַיִּתְפֹּֽצְﬞצוּ֙|2=א=וַיִּתְפֹּֽצֲצוּ֙ (חטף)"
          },
          " הַרְרֵי־עַ֔ד שַׁח֖וּ גִּבְע֣וֹת עוֹלָ֑ם הֲלִיכ֥וֹת עוֹלָ֖ם לֽוֹ׃"
        ]
      },
      "ז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ז"
        },
        "verse-body": [
          "תַּ֣חַת אָ֔וֶן רָאִ֖יתִי ",
          {
            "stmpl": "מ:קמץ|ד=אׇהֳלֵ֣י|ס=אָהֳלֵ֣י"
          },
          " כוּשָׁ֑ן יִרְגְּז֕וּן יְרִיע֖וֹת אֶ֥רֶץ מִדְיָֽן׃"
        ]
      },
      "ח": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ח"
        },
        "verse-body": [
          "הֲבִנְהָרִים֙ חָרָ֣ה יְהֹוָ֔ה אִ֤ם בַּנְּהָרִים֙ אַפֶּ֔ךָ אִם־בַּיָּ֖ם עֶבְרָתֶ֑ךָ כִּ֤י תִרְכַּב֙ עַל־סוּסֶ֔יךָ מַרְכְּבֹתֶ֖יךָ יְשׁוּעָֽה׃"
        ]
      },
      "ט": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|ט"
        },
        "verse-body": [
          "עֶרְיָ֤ה תֵעוֹר֙ קַשְׁתֶּ֔ךָ שְׁבֻע֥וֹת מַטּ֖וֹת אֹ֣מֶר סֶ֑לָה נְהָר֖וֹת תְּבַקַּע־אָֽרֶץ׃"
        ]
      },
      "י": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|י"
        },
        "verse-body": [
          "רָא֤וּךָ יָחִ֙ילוּ֙ הָרִ֔ים זֶ֥רֶם מַ֖יִם עָבָ֑ר נָתַ֤ן תְּהוֹם֙ קוֹל֔וֹ ר֖וֹם יָדֵ֥יהוּ נָשָֽׂא׃"
        ]
      },
      "יא": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יא"
        },
        "verse-body": [
          "שֶׁ֥מֶשׁ יָרֵ֖חַ עָ֣מַד זְבֻ֑לָה לְא֤וֹר חִצֶּ֙יךָ֙ יְהַלֵּ֔כוּ לְנֹ֖גַהּ בְּרַ֥ק חֲנִיתֶֽךָ׃"
        ]
      },
      "יב": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יב"
        },
        "verse-body": [
          "בְּזַ֖עַם תִּצְעַד־אָ֑רֶץ בְּאַ֖ף תָּד֥וּשׁ גּוֹיִֽם׃"
        ]
      },
      "יג": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יג"
        },
        "verse-body": [
          "יָצָ֙אתָ֙ לְיֵ֣שַׁע עַמֶּ֔ךָ לְיֵ֖שַׁע אֶת־מְשִׁיחֶ֑ךָ מָחַ֤צְתָּ רֹּאשׁ֙ מִבֵּ֣ית רָשָׁ֔ע עָר֛וֹת יְס֥וֹד עַד־צַוָּ֖אר סֶֽלָה׃"
        ]
      },
      "יד": {
        "prefix": [
          "¶",
          {
            "stmpl": "פפ"
          },
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יד"
        },
        "verse-body": [
          "נָקַ֤בְתָּ בְמַטָּיו֙ רֹ֣אשׁ ",
          {
            "stmpl": "קו\"כ-אם|פְּרָזָ֔ו|2=א,ל-קרי=פְּרָזָ֔יו"
          },
          " יִסְעֲר֖וּ לַהֲפִיצֵ֑נִי עֲלִ֣יצֻתָ֔ם כְּמוֹ־לֶאֱכֹ֥ל עָנִ֖י בַּמִּסְתָּֽר׃"
        ]
      },
      "טו": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|טו"
        },
        "verse-body": [
          "דָּרַ֥כְתָּ בַיָּ֖ם סוּסֶ֑יךָ חֹ֖מֶר מַ֥יִם רַבִּֽים׃"
        ]
      },
      "טז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|טז"
        },
        "verse-body": [
          "שָׁמַ֣עְתִּי",
          {
            "stmpl": "מ:לגרמיה-2"
          },
          " וַתִּרְגַּ֣ז בִּטְנִ֗י לְקוֹל֙ ",
          {
            "stmpl": "נוסח|צָלְﬞל֣וּ|2=א=צָלֲל֣וּ (חטף)"
          },
          " שְׂפָתַ֔י יָב֥וֹא רָקָ֛ב בַּעֲצָמַ֖י וְתַחְתַּ֣י אֶרְגָּ֑ז אֲשֶׁ֤ר אָנ֙וּחַ֙ לְי֣וֹם צָרָ֔ה לַעֲל֖וֹת לְעַ֥ם יְגוּדֶֽנּוּ׃"
        ]
      },
      "יז": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יז"
        },
        "verse-body": [
          "כִּֽי־תְאֵנָ֣ה לֹֽא־תִפְרָ֗ח וְאֵ֤ין יְבוּל֙ בַּגְּפָנִ֔ים כִּחֵשׁ֙ מַֽעֲשֵׂה־זַ֔יִת וּשְׁדֵמ֖וֹת לֹא־עָ֣שָׂה אֹ֑כֶל גָּזַ֤ר מִמִּכְלָה֙ צֹ֔אן וְאֵ֥ין בָּקָ֖ר בָּרְפָתִֽים׃"
        ]
      },
      "יח": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יח"
        },
        "verse-body": [
          "וַאֲנִ֖י בַּיהֹוָ֣ה אֶעְל֑וֹזָה אָגִ֖ילָה בֵּאלֹהֵ֥י יִשְׁעִֽי׃"
        ]
      },
      "יט": {
        "prefix": [
          "¶"
        ],
        "location": {
          "stmpl": "מ:פסוק|חבקוק|ג|יט"
        },
        "verse-body": [
          "יֱהֹוִ֤ה אֲדֹנָי֙ חֵילִ֔י וַיָּ֤שֶׂם רַגְלַי֙ כָּאַיָּל֔וֹת וְעַ֥ל בָּמוֹתַ֖י יַדְרִכֵ֑נִי לַמְנַצֵּ֖חַ בִּנְגִינוֹתָֽי׃"
        ]
      }
